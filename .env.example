# Optional default fallback endpoint
NEXT_PUBLIC_FORMSPREE_ENDPOINT=

# Development endpoint
NEXT_PUBLIC_FORMSPREE_ENDPOINT_DEV=https://formspree.io/f/your_dev_form_id

# Production endpoint
NEXT_PUBLIC_FORMSPREE_ENDPOINT_PROD=https://formspree.io/f/your_prod_form_id

# Analytics ingest endpoint (for example: https://www.echocode.digital/api/analytics/page-view)
NEXT_PUBLIC_ANALYTICS_INGEST_URL=

# Optional site identifier stored with each analytics event
NEXT_PUBLIC_ANALYTICS_SITE_ID=echocode_app
