# Site identity stored with analytics events and form submissions
NEXT_PUBLIC_SITE_ID=echocode_app

# Optional host override. Leave empty to use the current browser host automatically.
NEXT_PUBLIC_SITE_HOST=

NEXT_PUBLIC_ANALYTICS_INGEST_URL=

NEXT_PUBLIC_FORMS_SUBMIT_URL=

# Optional explicit upload-init endpoint. If omitted, it is derived from NEXT_PUBLIC_FORMS_SUBMIT_URL.
NEXT_PUBLIC_FORMS_UPLOAD_INIT_URL=
